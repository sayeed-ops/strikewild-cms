# Copy to .env.local and fill in real values. .env.local is gitignored.

# Public site URL (used in canonical, sitemap, OG tags, JSON-LD).
# Update this once the domain is purchased.
NEXT_PUBLIC_SITE_URL=https://strikewild.example.com

# Sanity project credentials.
# Create a project at https://www.sanity.io/manage and copy the values here.
# Both NEXT_PUBLIC_* (for the website) and SANITY_STUDIO_* (for the Studio)
# point at the same Sanity project — keep them in sync.
NEXT_PUBLIC_SANITY_PROJECT_ID=your-project-id
NEXT_PUBLIC_SANITY_DATASET=production
NEXT_PUBLIC_SANITY_API_VERSION=2024-10-01

SANITY_STUDIO_PROJECT_ID=your-project-id
SANITY_STUDIO_DATASET=production

# Write token for the one-off migration script (scripts/migrate-to-sanity.mjs).
# Create at https://www.sanity.io/manage > API > Tokens, with "Editor" or "Write" permissions.
# Delete this token after migration finishes.
SANITY_WRITE_TOKEN=
